class PrimeInRange
{
    public static boolean isPrime(int n){

        int count = 0;

        for(int i = 1; i <= n; i++){
            if(n % i == 0){
                count++;
            }
        }

        return count == 2;
    }

    public static void main(String[] args)
    {
        for(int i = 50; i <= 100; i++){

            if(isPrime(i)){
                System.out.println("Prime Numbers are: "+i);
            }

        }
    }
}