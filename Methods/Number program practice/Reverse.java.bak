import java.util.Scanner;
class Reverse
{
	static Scanner sc=new Scanner(System.in);
	
	public static int reverse(int n){
		int rev=1;
		
		while(n>0){
			int ld = n%10;
			rev = rev*10+ld;
			n=n/10;
		}
		return rev;
	}
	public static void main(String[] args) 
	{
		System.out.print("Enter one Number: ");
		int n=sc.nextInt();
		
		int ans = reverse(n);
		
	
		System.out.println(ans);

		
	}
}
