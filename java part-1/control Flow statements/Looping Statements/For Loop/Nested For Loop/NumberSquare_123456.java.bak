class NumberSquare_123456
{
	public static void main(String[] args) throws Exception
	{
		
		int n=3;
		
		int k=1;
		
		for(int i =0; i<n; i++)
		{
			for(int j=0; j<n; j++)
			{
				if (true)
				{
					System.out.print(k++ +" ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
				
			}
			System.out.println();
		}
	}
}

