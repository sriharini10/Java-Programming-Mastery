import java.util.Scanner;
class Factorial 
{
	static Scanner sc=new Scanner(System.in);
	public static int factorial(int n){
		
		int fact = 1;
		
		for (int i =1; i<=n ;i++ )
		{
			fact = fact *i;
		}
		return fact;
	}
	
	public static void main(String[] args) 
	{
		System.out.println("Enter one Number: ");
		int n =sc.nextInt();
		
		int ans =facorial(n);
		System.out.println(ans);
	}
}
