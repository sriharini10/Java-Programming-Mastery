class HappyNumber 
{
	public static int square(int num) {
		
        return num * num;
    }
	public static int SumOfSquare(int num){
		
		int res=0;
		
		while(num !=0 ){
			
			int last = num%10;
			
			res=res+square(last);
			
			num= num/10;
		}
		return res;
	}
	public static void main(String[] args) 
	{
		int number = 19;

        int result = SumOfSquare(number);

        System.out.println("Sum of squares: " + result);
	}
}
