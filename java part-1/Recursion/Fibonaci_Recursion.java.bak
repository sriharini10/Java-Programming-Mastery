class Fibonaci_Recursion 
{
	public static void fibonacci(int a,int b,int n){
		
		//base case
		if(n==0)
			return;
		
		int c = a + b;
		System.out.println(c);
		fibonacci(b,c,n-1);
		
		
	}
	public static void main(String[] args) 
	{
		int a = 0;
		int b = 1;
		int n = 7;
		System.out.print(a+" ");
		System.out.print(b+" ");
		fibonacci(a,b,n-2);
		
	}
}
