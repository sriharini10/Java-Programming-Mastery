class Printing_MyName
{
	public static void main(String[] args) throws Exception
	{
		int n=5;
		
		for(int i =0; i<n; i++)
		{
			//S
			
			for(int j=0; j<n; j++)
			{
				if (i==0 || i==n/2  || i==n-1 || j==n-1 && i>=n/2 ||j==0 && i<=n/2)
				{
					System.out.print("s ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
				
			//Space Between Two Letters
			System.out.print("    ");
			
			
			//R
			
			for(int j=0; j<n; j++)
			{
				if (j==0 || i==0  || i==n/2 || j==n-1 && i<=n/2 || i==j && i>=n/2)
				{
					System.out.print("r ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
				
			//Space Between Two Letters
			System.out.print("    ");
			
			//I
			
			for(int j=0; j<n; j++)
			{
				if (j==n/2 || i==0  || i==n-1 )
				{
					System.out.print("i ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
			
			//Space Between Two Letters
			System.out.print("    ");
			
			
			//H
			
			for(int j=0; j<n; j++)
			{
				if (i==n/2 || j==0  || j==n-1 )
				{
					System.out.print("h ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
			
			//Space Between Two Letters
			System.out.print("    ");
			
		   //A
			
			for(int j=0; j<n; j++)
			{
				if (i==n/2 || j==0  || j==n-1 || i==0 )
				{
					System.out.print("a ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
				
			//Space Between Two Letters
			System.out.print("    ");
			
			
			//R
			
			for(int j=0; j<n; j++)
			{
				if (j==0 || i==0  || i==n/2 || j==n-1 && i<=n/2 || i==j && i>=n/2)
				{
					System.out.print("r ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
				
			//Space Between Two Letters
			System.out.print("    ");
			
			//I
			
			for(int j=0; j<n; j++)
			{
				if (j==n/2 || i==0  || i==n-1 )
				{
					System.out.print("i ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
			
			//Space Between Two Letters
			System.out.print("    ");
			
		//Space Between Two Letters
			System.out.print("    ");
			
			
			//N
			
			for(int j=0; j<n; j++)
			{
				if (i==j|| j==0 || j==n-1)
				{
					System.out.print("n ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
				
			//Space Between Two Letters
			System.out.print("    ");
			
			//I
			
			for(int j=0; j<n; j++)
			{
				if (j==n/2 || i==0  || i==n-1 )
				{
					System.out.print("i ");
				}
				else
				{
					System.out.print("  ");
				}
				
				Thread.sleep(100);
			}
			
		
			System.out.println();
		}
	}
}
